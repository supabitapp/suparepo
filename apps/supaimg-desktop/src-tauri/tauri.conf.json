{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SupaIMG",
  "version": "1.4.0",
  "identifier": "app.supaimg.supaimg",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1000,
        "height": 700,
        "minWidth": 1000,
        "minHeight": 700,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4QTc3RTZFOEFGNDQ1RDkKUldUWlJmU0tibjZuK01vUng3REdxUHRXZmVVM3JORVBUakxsLzZGd3lzUVhYdlRDeFBiNlBOY04K",
      "endpoints": ["https://appcast.supaimg.app/supaimg/update.json"]
    }
  }
}
