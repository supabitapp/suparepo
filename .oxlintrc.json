{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "plugins": ["react", "react-perf", "jsx-a11y", "import", "typescript", "unicorn", "vitest"],
  "rules": {
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": [
      "warn",
      {
        "allow": ["**/*.css", "**/next-env.d.ts", "**/.next/**"]
      }
    ]
  },
  "ignorePatterns": ["dist", "node_modules", "src-tauri/target", ".next", "**/routeTree.gen.ts"],
  "overrides": [
    {
      "files": ["apps/supabit.app/**/*.{ts,tsx}"],
      "plugins": ["nextjs"]
    },
    {
      "files": ["**/*.test.{ts,tsx}", "**/*.spec.{ts,tsx}"],
      "env": {
        "vitest": true
      }
    }
  ]
}
